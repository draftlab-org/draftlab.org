---
import { getCollection } from 'astro:content';
import Image from '@components/atoms/Image.astro';
import Link from '@components/atoms/Link.astro';
import { isVisible } from '@utils/content';

export interface Props {
  category?: string;
}

const { category } = Astro.props;

const peopleEntries = await getCollection('people');
const allPeople = peopleEntries
  .filter((entry) => isVisible(entry))
  .map((entry) => entry.data);

const people = category
  ? allPeople.filter((person) => person.sections.includes(category))
  : allPeople;
---

<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-2">
  {people.map((person) => (
    <div class="flex gap-5">
      {person.headshot && (
        <div class="flex-shrink-0">
          <Image
            src={person.headshot}
            alt={person.name}
            width={120}
            height={120}
            class="h-24 w-24 rounded-lg object-cover"
          />
        </div>
      )}
      <div class="min-w-0">
        <h3 class="font-serif text-lg font-normal text-ink">
          {person.url ? (
            <Link href={person.url} variant="unstyled" class="underline decoration-sand decoration-1 underline-offset-2 hover:decoration-secondary-400" external>
              {person.name}
            </Link>
          ) : (
            person.name
          )}
        </h3>
        {person.bio && (
          <p class="mt-2 text-sm leading-relaxed text-ink-soft">
            {person.bio}
          </p>
        )}
      </div>
    </div>
  ))}
</div>

{people.length === 0 && (
  <div class="py-12 text-center text-gray-500">
    No people found.
  </div>
)}
