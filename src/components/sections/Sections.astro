---
import ButtonSection from '@components/sections/ButtonSection.astro';
import CardSection from '@components/sections/CardSection.astro';
import FlexiSection from '@components/sections/FlexiSection.astro';
import FrameworkSection from '@components/sections/FrameworkSection.astro';
import HeroSection from '@components/sections/HeroSection.astro';
import ModalitiesOverviewSection from '@components/sections/ModalitiesOverviewSection.astro';
import OrganisationsRollSection from '@components/sections/OrganisationsRollSection.astro';
import PeopleSection from '@components/sections/PeopleSection.astro';
import PhasesOverviewSection from '@components/sections/PhasesOverviewSection.astro';
import ProjectsRollSection from '@components/sections/ProjectsRollSection.astro';
import RichTextSection from '@components/sections/RichTextSection.astro';
import SectionLayout from '@layouts/SectionLayout.astro';

const { sectionItems } = Astro.props;

---

{
  sectionItems.map((section: any) => {
    const sectionLabel = `section > ${section.type}`;

    const content = (() => {
      switch (section.type) {
        case 'button':
          return (
            <ButtonSection
              title={section.title}
              buttons={section.buttons}
            />
          );
        case 'flexi':
          return (
            <FlexiSection
              title={section.title}
              description={section.description}
              sections={section.sections}
            />
          );
        case 'hero':
          return (
            <HeroSection
              title={section.title}
              subtitle={section.subtitle}
            />
          );
        case 'richText':
          return (
            <RichTextSection
              background={section.background}
              content={section.content}
              withTOC={section.withTOC}
            />
          );
        case 'card':
          return (
            <CardSection
              title={section.title}
              description={section.description}
              cards={section.cards}
              buttons={section.buttons}
            />
          );
        case 'people':
          return (
            <PeopleSection
              category={section.category}
            />
          );
        case 'framework':
          return (
            <FrameworkSection
              title={section.title}
              description={section.description}
              showProjects={section.showProjects}
            />
          );
        case 'projectsRoll':
          return (
            <ProjectsRollSection
              title={section.title}
              description={section.description}
              limit={section.limit}
              filterPhase={section.filterPhase}
              filterModality={section.filterModality}
              featuredOnly={section.featuredOnly}
            />
          );
        case 'phasesOverview':
          return (
            <PhasesOverviewSection
              title={section.title}
              description={section.description}
            />
          );
        case 'modalitiesOverview':
          return (
            <ModalitiesOverviewSection
              title={section.title}
              description={section.description}
            />
          );
        case 'organisationsRoll':
          return (
            <OrganisationsRollSection
              title={section.title}
              description={section.description}
              filterType={section.filterType}
              limit={section.limit}
            />
          );
        default:
          return null;
      }
    })();

    return (
      <SectionLayout
        bgColor={section.background?.bgColor}
        bgType={section.background?.bgType}
        bgImage={section.backgroundImage}
        class={section.class}
        sectionLabel={sectionLabel}
      >
        {content}
      </SectionLayout>
    );
  })
}
