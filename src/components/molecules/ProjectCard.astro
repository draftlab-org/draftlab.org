---
import PhaseTag from '@components/molecules/PhaseTag.astro';

export interface Props {
  name: string;
  description: string;
  organisation?: string;
  phases: Array<'understand' | 'define' | 'build' | 'sustain'>;
  active?: boolean;
  featured?: boolean;
  class?: string;
}

const {
  name,
  description,
  organisation,
  phases,
  active = false,
  featured = false,
  class: className = '',
} = Astro.props;
---

<article
  class:list={[
    'group relative rounded-lg border-2 border-sand bg-cream p-5 transition-colors duration-150 hover:border-secondary-400',
    featured && 'ring-1 ring-secondary-200',
    className,
  ]}
>
  {/* Phase color bar */}
  {phases[0] && (
    <div
      class:list={[
        'absolute top-0 left-0 right-0 h-[3px] rounded-t-lg opacity-50',
        phases[0] === 'understand' && 'bg-phase-understand',
        phases[0] === 'define' && 'bg-phase-define',
        phases[0] === 'build' && 'bg-phase-build',
        phases[0] === 'sustain' && 'bg-phase-sustain',
      ]}
    />
  )}

  <div class="flex items-start justify-between gap-3">
    <h3 class="font-serif text-lg font-normal leading-tight text-ink">
      {name}
    </h3>
    {active && (
      <span class="mt-0.5 flex-shrink-0 rounded-full bg-phase-understand-light px-2 py-0.5 text-[0.65rem] font-medium text-phase-understand-dark">
        Active
      </span>
    )}
  </div>

  {organisation && (
    <p class="mt-1 text-xs italic text-ink-muted">{organisation}</p>
  )}

  <p class="mt-3 text-sm leading-relaxed text-ink-soft">{description}</p>

  <div class="mt-4 flex flex-wrap gap-1.5">
    {phases.map((phase) => (
      <PhaseTag phase={phase}>
        {phase.charAt(0).toUpperCase() + phase.slice(1)}
      </PhaseTag>
    ))}
  </div>
</article>
